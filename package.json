{
  "name": "dataplotter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "cross-env ELECTRON=1 npm run build && electron-builder",
    "tauri": "tauri"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/openai": "^3.0.41",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.116",
    "electron-updater": "^6.8.3",
    "jstat": "^1.9.6",
    "jszip": "^3.10.1",
    "ml-levenberg-marquardt": "^5.0.0",
    "nanoid": "^5.1.6",
    "papaparse": "^5.5.3",
    "plotly.js": "^3.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-plotly.js": "^2.6.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "cypress": "^15.11.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.dataplotter.app",
    "productName": "Dataplotter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "electron"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": ["**/*.py"]
      }
    ],
    "publish": "github",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
