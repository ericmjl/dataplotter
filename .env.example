# Optional: API keys for Chat (natural language). Set at least one.
# Provider order: Groq → Anthropic → OpenAI-compatible custom endpoint.
#
# Groq (https://console.groq.com)
# VITE_GROQ_API_KEY=gsk_...
#
# Anthropic (https://console.anthropic.com)
# VITE_ANTHROPIC_API_KEY=sk-ant-...
#
# Custom OpenAI-compatible endpoint (any API that speaks OpenAI chat completions)
# VITE_OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
# VITE_OPENAI_COMPATIBLE_API_KEY=sk-...
# VITE_OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
